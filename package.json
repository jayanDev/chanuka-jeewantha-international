{
  "name": "next-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "prisma generate",
    "pretest": "npm run db:push",
    "dev": "node ./scripts/next-wrapper.cjs dev --webpack",
    "build": "node ./scripts/next-wrapper.cjs build --webpack",
    "start": "node ./scripts/next-wrapper.cjs start",
    "lint": "eslint src prisma next.config.ts postcss.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run lint && npm run typecheck && npm run test",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "@vercel/blob": "^2.3.3",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.7.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "prisma": "^6.16.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "postcss": "8.5.12"
  }
}
