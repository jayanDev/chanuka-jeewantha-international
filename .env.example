# SQLite dev DB (fast local setup)
DATABASE_URL="file:./dev.db"

# Optional: use PostgreSQL in production, for example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Seeded admin credentials (change for production)
ADMIN_EMAIL="admin@chanuka.local"
ADMIN_PASSWORD="Admin@12345"
ADMIN_NAME="Chanuka Admin"

# Notification hooks (optional)
# If all three email variables are set, order notifications are sent via Resend.
RESEND_API_KEY=""
NOTIFICATION_EMAIL_FROM="orders@yourdomain.com"
NOTIFICATION_EMAIL_TO="yourinbox@yourdomain.com"

# Optional WhatsApp/webhook notification endpoint
# Example: your own webhook that forwards messages to WhatsApp/Telegram/Slack.
WHATSAPP_NOTIFY_WEBHOOK_URL=""

# Firebase Admin (Firestore)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
# Keep literal \n sequences in private key value.
FIREBASE_PRIVATE_KEY=""
# Optional but recommended for file uploads when using Firebase Storage.
# Example: your-project-id.appspot.com
FIREBASE_STORAGE_BUCKET=""

# Optional: Vercel Blob upload token. If set, uploads use Vercel Blob first.
BLOB_READ_WRITE_TOKEN=""

# Google Analytics 4 (optional)
# Example: G-ABC123XYZ9
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Google Search Console verification token (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# Google OAuth (Sign In / Sign Up)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional comma-separated admin emails for Google OAuth users.
GOOGLE_ADMIN_EMAILS=""
